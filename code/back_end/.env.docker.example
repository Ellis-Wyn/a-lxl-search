# ==============================================
# 病理AI药研情报库 - Docker环境变量配置模板
# ==============================================
# 用途：Docker Compose使用的环境变量模板
# 使用：复制此文件为 .env.docker 并修改配置
# ==============================================

# ==================== 数据库配置 ====================
POSTGRES_USER=pathology_user
POSTGRES_PASSWORD=pathology_pass_123
POSTGRES_DB=pathology_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://pathology_user:pathology_pass_123@postgres:5432/pathology_db

# ==================== Redis配置 ====================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# ==================== 应用配置 ====================
DEBUG=False
SECRET_KEY=change-this-to-a-random-secret-key-in-production
CORS_ORIGINS=http://localhost:8000,http://localhost:3000,http://localhost:8080

# ==================== PubMed API配置 ====================
# PubMed邮箱（必需，用于API请求）
PUBMED_EMAIL=your-email@example.com
# PubMed API Key（可选，提高请求限制）
PUBMED_API_KEY=

# ==================== 邮件配置（可选） ====================
# SMTP服务器配置
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
# 预警邮件配置
ALERT_EMAIL_FROM=your-email@gmail.com
ALERT_EMAIL_TO=admin@example.com
ALERT_EMAIL_ENABLED=False

# ==================== 日志配置 ====================
LOG_LEVEL=INFO
LOG_FORMAT=json  # json 或 text

# ==================== 爬虫配置 ====================
# 请求速率限制（每秒请求数）
CRAWLER_RATE_LIMIT=0.5
# 请求重试次数
CRAWLER_MAX_RETRIES=3
# 请求超时时间（秒）
CRAWLER_TIMEOUT=30

# ==================== 调度器配置 ====================
# 是否启用自动调度
SCHEDULER_ENABLED=True
# 调度器时区
SCHEDULER_TIMEZONE=Asia/Shanghai

# ==================== 缓存配置 ====================
# Redis缓存过期时间（秒）
CACHE_TTL=300
# 是否启用缓存
CACHE_ENABLED=True
