# =====================================================
# 环境变量配置文件
# =====================================================
#
# 使用方法：
# 1. 复制此文件为 .env：cp .env.example .env
# 2. 填写您的实际配置值（不要提交 .env 到 Git）
# 3. .env 文件会被自动读取
#
# =====================================================

# =====================================================
# 应用基础配置
# =====================================================
APP_NAME="病理AI药研情报库"
APP_VERSION="1.0.0"
DEBUG=true

# =====================================================
# 数据库配置（必填）
# =====================================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=drug_intelligence_db
DB_USER=postgres
DB_PASSWORD=your_password_here

# =====================================================
# PubMed API 配置
# =====================================================
# API Key（可选，但推荐获取以提升Rate Limit）
# 获取地址：https://www.ncbi.nlm.nih.gov/account/
PUBMED_API_KEY=

# 您的邮箱（必填，NCBI要求）
PUBMED_EMAIL=your_email@example.com

# =====================================================
# 爬虫配置
# =====================================================
# 请求间隔（秒）：遵守网站Rate Limit
CRAWLER_DELAY=0.3

# 药企官网爬虫（是否启用）
COMPANY_CRAWLER_ENABLED=true

# CDE平台爬虫（是否启用）
CDE_CRAWLER_ENABLED=true

# 专利爬虫（是否启用）
PATENT_CRAWLER_ENABLED=true

# =====================================================
# 预警配置
# =====================================================
# Phase Jump 预警（是否启用）
ALERT_PHASE_JUMP_ENABLED=true

# 竞品退场阈值（天）
ALERT_DISAPPEARED_THRESHOLD=21

# =====================================================
# 日志配置
# =====================================================
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
