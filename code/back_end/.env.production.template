# ==============================================
# 生产环境配置模板
# ==============================================
# 使用方法：
# 1. 复制此文件为 .env.production
# 2. 修改所有标记为 [需要修改] 的值
# 3. 部署时使用: docker-compose --env-file .env.production up -d
# ==============================================

# ==================== 数据库配置 ====================
POSTGRES_USER=pathology_ai
POSTGRES_PASSWORD=[设置强密码-至少16位包含大小写字母数字特殊字符]
POSTGRES_DB=pathology_ai
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# 数据库连接URL（Docker内部网络）
DATABASE_URL=postgresql://pathology_ai:[设置强密码]@postgres:5432/pathology_ai

# ==================== Redis配置 ====================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0
REDIS_PASSWORD=  # 如果需要密码认证

# ==================== API配置 ====================
API_HOST=0.0.0.0
API_PORT=8000

# CORS配置（允许的前端域名）
# ⚠️ 必须添加你的Vercel域名和API域名
CORS_ORIGINS=["https://your-project.vercel.app","https://api.your-domain.com"]

# 应用密钥
SECRET_KEY=[生成随机密钥-使用 openssl rand -hex 32]
DEBUG=False

# ==================== PubMed配置 ====================
# ⚠️ 生产环境必须配置，避免限流
PUBMED_EMAIL=[你的邮箱]
PUBMED_API_KEY=[从 https://www.ncbi.nlm.nih.gov/account/ 获取]

# ==================== 爬虫配置 ====================
# 生产环境建议设置为false，手动触发爬虫
CRAWLER_ENABLED=false
CRAWLER_SCHEDULED=false

# 爬虫并发控制
CRAWLER_MAX_CONCURRENT=2
CRAWLER_DELAY_MIN=0.3
CRAWLER_DELAY_MAX=0.8

# ==================== 邮件告警配置（可选）====================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=[你的邮箱]
SMTP_PASSWORD=[应用专用密码]
SMTP_USE_TLS=true

ALERT_EMAIL_FROM=[你的邮箱]
ALERT_EMAIL_TO=[接收告警的邮箱]
ALERT_EMAIL_ENABLED=false  # 设置为true启用告警

# ==================== 日志配置 ====================
LOG_LEVEL=INFO
LOG_FILE_PATH=/app/logs/pathology_ai.log
LOG_ROTATION=500 MB  # 日志文件最大大小
LOG_RETENTION=30 days  # 日志保留时间

# ==================== 缓存配置 ====================
CACHE_ENABLED=true
CACHE_TTL=3600  # 缓存过期时间（秒）

# ==================== 安全配置 ====================
# 允许的IP范围（可选，限制API访问）
# ALLOWED_IPS=["0.0.0.0/0"]

# 速率限制
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60

# ==================== 监控配置（可选）====================
SENTRY_DSN=  # Sentry错误追踪
METRICS_ENABLED=false

# ==================== 备份配置 ====================
BACKUP_ENABLED=true
BACKUP_RETENTION_DAYS=30
BACKUP_SCHEDULE="0 2 * * *"  # 每天凌晨2点备份

# ==================== SSL/HTTPS（Nginx配置）====================
# 这些配置用于Nginx反向代理
NGINX_SERVER_NAME=api.your-domain.com

# ==================== 其他 ====================
ENVIRONMENT=production
TZ=Asia/Shanghai

# ==============================================
# 部署前检查清单
# ==============================================
# [ ] 所有密码已修改为强密码
# [ ] CORS_ORIGINS已添加正确的域名
# [ ] PUBMED_API_KEY已配置（避免限流）
# [ ] SECRET_KEY已生成随机值
# [ ] 邮件告警已配置（如需要）
# [ ] CRAWLER_ENABLED已设置正确（建议false）
# ==============================================
