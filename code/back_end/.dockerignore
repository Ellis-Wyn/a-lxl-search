# ==============================================
# Docker 构建忽略文件
# ==============================================
# 用途：排除不需要打包到Docker镜像的文件
# 原因：加快构建速度，减小镜像体积
# ==============================================

# Python缓存
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# 虚拟环境
venv/
env/
ENV/
.venv/

# IDE配置
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# 日志文件
logs/
*.log

# 数据库文件
*.db
*.sqlite
*.sqlite3

# 环境变量（使用docker-compose的环境变量）
.env
.env.local
.env.*.local

# Git
.git/
.gitignore
.gitattributes

# Docker文件（避免递归）
Dockerfile
docker-compose.yml
.dockerignore

# 测试和覆盖率
.pytest_cache/
.coverage
htmlcov/
.tox/

# 文档和临时文件
*.md
docs/
*.tmp
*.bak

# 操作系统文件
Thumbs.db
.DS_Store

# Node modules (如果有前端)
node_modules/
npm-debug.log

# 数据备份
*.sql.gz
*.sql.backup

# 开发工具配置
.pytest_cache/
.mypy_cache/
.dmypy.json
dmypy.json
